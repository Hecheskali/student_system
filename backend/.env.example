APP_NAME=Student System API
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./student_system.db
JWT_SECRET_KEY=change-this-to-a-random-64-character-secret-value
ACCESS_TOKEN_EXPIRE_MINUTES=15
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ACCOUNT_LOCKOUT_MINUTES=15
TRUSTED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
ENABLE_HTTPS_REDIRECT=false
ENABLE_HSTS=false
ENABLE_DOCS=true
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisPassword!123
BOOTSTRAP_ADMIN_NAME=System Administrator

